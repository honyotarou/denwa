{
  "name": "denwa",
  "private": true,
  "workspaces": [
    "packages/pbx-core",
    "packages/pbx-db",
    "packages/pbx-infra",
    "packages/pbx-ops",
    "apps/web"
  ],
  "scripts": {
    "test": "npm run test -w @openpbx/core",
    "test:watch": "npm run test:watch -w @openpbx/core",
    "test:gate": "npm run test -w @openpbx/core && npm run test -w @openpbx/ops && npm run test -w @openpbx/db && npm run test -w @openpbx/infra && npm run test -w command-room-web",
    "test:roadmap": "npm run test -w @openpbx/core -- --reporter=verbose",
    "harness": "bash scripts/harness-check.sh",
    "harness:fast": "bash scripts/harness-fast.sh",
    "check:static": "node scripts/check-denwa-static.mjs",
    "test:e2e": "playwright test -c e2e/playwright.config.mjs",
    "test:e2e:install": "playwright install chromium",
    "prod-check": "npx tsx scripts/prod-check.ts",
    "prepare": "lefthook install || true"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "lefthook": "^1.11.14",
    "tsx": "^4.19.4"
  }
}
