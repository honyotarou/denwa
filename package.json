{
  "name": "denwa",
  "private": true,
  "workspaces": [
    "packages/pbx-core",
    "packages/pbx-db",
    "packages/pbx-infra",
    "packages/pbx-ops",
    "apps/web"
  ],
  "scripts": {
    "test": "npm run test -w @openpbx/core",
    "test:watch": "npm run test:watch -w @openpbx/core",
    "test:gate": "npm run build:chrome-ext && npm run test -w @openpbx/core && npm run test -w @openpbx/ops && npm run test -w @openpbx/db && npm run test -w @openpbx/infra && npm run test -w command-room-web",
    "test:coverage:parity-b": "npm run test -w @openpbx/core -- --coverage",
    "test:coverage:softphone": "npm run test -w @openpbx/core -- --coverage src/__tests__/softphone-state.test.ts src/__tests__/openpbx-gap.test.ts src/__tests__/gap-phase4-5.test.ts src/__tests__/gap-l5-runtime.test.ts src/__tests__/wss-readiness.test.ts",
    "bench:softphone": "npm run bench -w @openpbx/core -- src/__bench__/softphone-state.bench.ts",
    "test:roadmap": "npm run test -w @openpbx/core -- --reporter=verbose",
    "harness": "bash scripts/harness-check.sh",
    "harness:fast": "bash scripts/harness-fast.sh",
    "check:static": "node scripts/check-denwa-static.mjs",
    "build:chrome-ext": "node scripts/bundle-chrome-extension.mjs",
    "test:e2e": "playwright test -c e2e/playwright.config.mjs",
    "test:e2e:install": "playwright install chromium",
    "prod-check": "npx tsx scripts/prod-check.ts",
    "rotate:exposed-secrets": "npx tsx scripts/rotate-exposed-secrets.ts",
    "prepare": "lefthook install || true"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "lefthook": "^1.11.14",
    "postcss": "8.5.10",
    "tsx": "^4.19.4"
  },
  "overrides": {
    "postcss": "8.5.10",
    "esbuild": "0.25.12",
    "vite": "6.4.2"
  }
}
