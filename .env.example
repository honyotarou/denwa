# Copy to .env for docker compose up (required — no defaults in compose)
AMI_SECRET=change-me-generate-random-ami-secret
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=change-me-generate-base64-32bytes
# 本番 inbox: 設定時は meta.json に HMAC 必須（T-SEC-INBOX-002）。開発は空で可。
INBOX_HMAC_SECRET=
# docker compose の web（NODE_ENV=production）用。未設定時は compose がローカル向け CIDR を入れる。
# IP_ALLOW_CIDRS=127.0.0.0/8,172.28.0.0/16
